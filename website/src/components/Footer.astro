---
import Logo from './Logo.astro';
import { siteConfig } from '../data/config';
---

<footer role="contentinfo" class="border-t border-border mt-24" data-animate>
  <div class="max-w-7xl mx-auto px-6 py-12 flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2.5">
      <Logo width={20} height={20} />
      <span class="text-sm text-text-muted">MIT License &middot; Built by <a href={siteConfig.author.url} target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-text-primary transition-colors duration-150 underline underline-offset-2">{siteConfig.author.name}</a></span>
    </div>
    <div class="flex items-center gap-5 text-sm">
      <a href="/getting-started/installation/" data-astro-prefetch class="text-text-muted hover:text-text-primary transition-colors duration-150 no-underline">Documentation</a>
      <a href={siteConfig.github} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-text-primary transition-colors duration-150 no-underline">GitHub</a>
      <a href={siteConfig.pkgGoDev} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-text-primary transition-colors duration-150 no-underline">pkg.go.dev</a>
    </div>
  </div>
</footer>
