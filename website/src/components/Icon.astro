const allIcons: Record<IconName, string> = { ...featureIconPaths, ...useCaseIconPaths, ...uiIconPaths };
const pathContent = allIcons[name];
---

{pathContent && <svg width={size} height={size} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><Fragment set:html={pathContent} /></svg>}
