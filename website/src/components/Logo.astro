---
export interface Props {
  width?: number;
  height?: number;
  class?: string;
}

const { width = 28, height = 28, class: className } = Astro.props;
---

<svg class={className} width={width} height={height} viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="templ-components logo">
  <rect width="28" height="28" rx="6" class="fill-[var(--color-accent)]" />
  <path d="M10 9L5 14l5 5M18 9l5 5-5 5M15.5 7l-3 14" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
</svg>
