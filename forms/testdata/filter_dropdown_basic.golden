<div class="flex-col inline-flex"><label class="block dark:text-gray-400 font-medium mb-1 text-gray-600 text-xs">Status</label> <select name="status" class="bg-white block border-0 caret-blue-600 dark:bg-gray-800 dark:caret-blue-400 dark:focus:ring-blue-500 dark:ring-gray-600 dark:text-white focus:ring-2 focus:ring-blue-600 focus:ring-inset pe-8 ps-3 py-1.5 ring-1 ring-gray-300 ring-inset rounded-md text-gray-900 text-sm" hx-get="/api/users" hx-target="#user-list" hx-trigger="change"><option value="all">All</option><option value="active" selected>Active</option><option value="inactive">Inactive</option></select> </div>