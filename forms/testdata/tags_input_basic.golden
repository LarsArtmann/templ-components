<div class="space-y-1"><label for="tags" class="block dark:text-white font-medium text-gray-900 text-sm">Tags </label><div class="bg-white border-0 dark:bg-gray-800 dark:focus-within:ring-blue-500 dark:ring-gray-600 flex flex-wrap focus-within:ring-2 focus-within:ring-blue-600 focus-within:ring-inset gap-2 items-center motion-reduce:transition-none px-3 py-2 ring-1 ring-gray-300 ring-inset rounded-md transition-shadow" data-tc-tags="tags"><span class="bg-blue-50 dark:bg-blue-900/50 dark:text-blue-300 font-medium gap-1 inline-flex items-center px-2 py-0.5 rounded-md text-blue-700 text-xs" data-tc-tag="Go">Go <button type="button" class="dark:hover:text-blue-200 dark:text-blue-400 hover:text-blue-600 text-blue-400" aria-label="Remove Go" data-tc-tag-remove="Go"><svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg></button></span> <input type="hidden" name="tags" value="Go"> <span class="bg-blue-50 dark:bg-blue-900/50 dark:text-blue-300 font-medium gap-1 inline-flex items-center px-2 py-0.5 rounded-md text-blue-700 text-xs" data-tc-tag="Templ">Templ <button type="button" class="dark:hover:text-blue-200 dark:text-blue-400 hover:text-blue-600 text-blue-400" aria-label="Remove Templ" data-tc-tag-remove="Templ"><svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg></button></span> <input type="hidden" name="tags" value="Templ"> <input type="text" class="bg-transparent border-0 caret-blue-600 dark:caret-blue-400 dark:placeholder:text-gray-500 dark:text-white flex-1 min-w-[120px] outline-none placeholder:text-gray-400 text-gray-900 text-sm" placeholder="Add tag..." data-tc-tags-input></div></div>