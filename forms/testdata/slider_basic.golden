<div class="space-y-1"><div class="flex items-center justify-between"><label class="dark:text-white font-medium text-gray-900 text-sm">Volume </label> <span class="dark:text-gray-400 font-medium text-gray-500 text-sm" data-slider-value>50</span></div><input type="range" name="volume" min="0" max="100" value="50" step="5" class="accent-blue-600 appearance-none bg-gray-200 cursor-pointer dark:accent-blue-400 dark:bg-gray-700 dark:focus:ring-blue-500 disabled:cursor-not-allowed disabled:opacity-50 focus:outline-none focus:ring-2 focus:ring-blue-600 h-2 rounded-lg w-full"> </div>