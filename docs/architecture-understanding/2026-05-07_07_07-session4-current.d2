# Issues
issues: {
  shape: rectangle
  near: bottom-right
  style.fill: "#FFEBEE"

  i1: "NavLinkProps.Attrs shadows BaseProps.Attrs (split brain)"
  i2: "htmx imports feedback.Spinner (tight coupling)"
  i3: "htmx calls feedback tcShowToast() in JS (hidden coupling)"
  i4: "icons.IconAttrs exported but never used"
  i5: "3 different JS attachment patterns"
  i6: "Badge has 2 separate color maps (drift risk)"
  i7: "Alert/Toast dismiss JS duplicated"
  i8: "Toast SVG paths duplicated Go + JS"
}
