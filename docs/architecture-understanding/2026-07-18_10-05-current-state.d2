direction: down

title: |md
  # templ-components — Current Architecture (v0.18.0)
  **Production package dependency graph · 13 packages · 3 external deps · acyclic**
| {near: top-center}

external: External Dependencies {
  style.fill: "#fdf2f8"
  style.stroke: "#9d174d"
  templ: "github.com/a-h/templ\n(rendering)" {shape: cylinder; style.fill: "#fce7f3"}
  twmerge: "tailwind-merge-go\n(Class() dedup)" {shape: cylinder; style.fill: "#fce7f3"}
  errfamily: "go-error-family\n(error classification)" {shape: cylinder; style.fill: "#fce7f3"}
}

stdlib: Go Stdlib {
  style.fill: "#f1f5f9"
  style.stroke: "#475569"
  fmt
  time
  net/url
  crypto/rand
  encoding/json
  sync
  sort
  strings
  errors
}

leaf: Leaf Layer {
  style.fill: "#ecfdf5"
  style.stroke: "#065f46"

  utils: utils {
    style.fill: "#d1fae5"
    style.fill: "#d1fae5"
    "BaseProps · ComponentProps\nClass() · Lookup() · EnsureID\nmotion constants · Version"
  }
  svg: internal/svg {
    style.fill: "#d1fae5"
    "SVG path constants\n(single source of truth)"
  }
}

shared: Shared Layer {
  style.fill: "#eff6ff"
  style.stroke: "#1e40af"

  icons: icons {
    style.fill: "#dbeafe"
    "102 Name consts · IconPathData\nIconPathJS · RTL mirroring\n(depends only on svg+utils+templ)"
  }
}

