  style.fill: "#fffbeb"
  style.stroke: "#92400e"

  display: display {
    style.fill: "#fef3c7"
    "30 components · ~12.5k LOC\nfan-out: 5 (largest)"
  }
  feedback: feedback {
    style.fill: "#fef3c7"
    "13 components · feedbackStyleSet\nshared styles.go"
  }
  forms: forms {
    style.fill: "#fef3c7"
    "21 components · InputType/EnterKeyHint\nSanitizeID · ErrorAttrs"
  }
  layout: layout {
    style.fill: "#fef3c7"
    "6 components · Page/Base/Minimal\nThemeScript · ThemeToggle · SRI"
  }
  navigation: navigation {
    style.fill: "#fef3c7"
    "12 components · NavLink shared\nSidebarNav · Breadcrumbs JSON-LD"
  }
  htmx: htmx {
    style.fill: "#fef3c7"
    "8 components · loading/error\nSwapOOB · ViewTransitions"
  }
  errorpage: errorpage {
