direction: down

title: |md
  # templ-components — Current Architecture (2026-05-04)
  56 templ components, 44 exported types, 42 icons | {near: top-center}

# FOUNDATION LAYER

foundation: Foundation Layer {
  style.fill: "#e8f5e9"
  style.stroke: "#2e7d32"
  style.stroke-width: 2

  utils: utils {
    style.fill: "#c8e6c9"
    BaseProps: "BaseProps struct (ID, Class, Attrs, AriaLabel, Nonce)"
    helpers: "Class() MergeAttrs() Ternary[T]() Ptr[T]() MapEnum[T]()"
  }

  internal_svg: "internal/svg" {
    style.fill: "#c8e6c9"
    FillIcon: "FillIcon(class, path, rotate...)"
    SpinnerSVG: "SpinnerSVG()"
  }
}

# ICON LAYER

icons_layer: icons {
  style.fill: "#fff3e0"
  style.stroke: "#e65100"
  style.stroke-width: 2

  icon_comp: "Icon(name, class)" {
    style.fill: "#ffe0b2"
  }
  icon_names: "42 Name constants" {
    style.fill: "#ffe0b2"
  }
}

# COMPONENT LAYER

components: Component Packages {
  style.fill: "#e3f2fd"
  style.stroke: "#1565c0"
  style.stroke-width: 2

  display: display {
    style.fill: "#bbdefb"
    desc: "15 components: Accordion, Avatar, Badge, Card, StatCard, Dropdown, EmptyState, Modal, Table, Tabs, Tooltip"
  }

  feedback: feedback {
    style.fill: "#bbdefb"
    desc: "12 components: Alert, Toast, Spinner, Skeleton, ProgressBar, StepIndicator, LoadingOverlay"
  }

  forms: forms {
    style.fill: "#bbdefb"
    desc: "6 components: Input, Select, Textarea, Checkbox, Label, FieldError"
  }

  htmx_pkg: htmx {
    style.fill: "#bbdefb"
    desc: "7 components: GlobalErrorHandling, LoadingIndicator, ConfirmDelete, SwapOOB, CSRFToken, LoadingButton"
  }

  navigation: navigation {
    style.fill: "#bbdefb"
    desc: "9 components: Nav, NavLink, MobileMenu, Breadcrumbs, Pagination, Footer"
  }

  layout: layout {
    style.fill: "#bbdefb"
    desc: "4 components: Base, Minimal, ThemeScript, ThemeToggle + PageProps"
  }
}

