# CONSUMERS

consumers: Consuming Projects {
  style.fill: "#f3e5f5"
  style.stroke: "#6a1b9a"
  style.stroke-width: 2

  consumer_apps: "Go web applications" {
    style.fill: "#e1bee7"
    style.stroke-dash: 3
  }
}

# KNOWN ISSUES

issues: Known Issues {
  style.fill: "#fff9c4"
  style.stroke: "#f57f17"
  style.stroke-dash: 5

  split_brains: "Split Brains: alertStyleSet equals toastStyleSet, alertStyles equals toastStyles"
  shallow: "Shallow: icon.templ 187-line switch, form error pattern repeated x4"
}

# IMPORT GRAPH

deps.templ -> foundation.utils: "templ.Component rendering"
deps.tw_merge -> foundation.utils: "class merging"

foundation.utils -> components.display: "BaseProps, Class()"
foundation.utils -> components.feedback: "BaseProps, Class()"
foundation.utils -> components.forms: "BaseProps, Class()"
foundation.utils -> components.navigation: "BaseProps, Class()"
foundation.utils -> components.layout: "MapEnum, Class()"

foundation.internal_svg -> components.display: "FillIcon, SpinnerSVG"
foundation.internal_svg -> components.feedback: "SpinnerSVG"
foundation.internal_svg -> icons_layer: "FillIcon"

icons_layer -> components.display: "Icon() in EmptyState"

components -> consumers.consumer_apps: "go get"

components.display -> issues
components.feedback -> issues
