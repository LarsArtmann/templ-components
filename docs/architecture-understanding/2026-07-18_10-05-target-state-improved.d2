direction: down

title: |md
  # templ-components — Target Architecture (post-v1.0)
  **Per-package go.mod coordinated by go.work · selective imports · enforced boundaries**
| {near: top-center}

workspace: "go.work (workspace coordinator)" {
  style.fill: "#f5f3ff"
  style.stroke: "#5b21b6"
  shape: package
}

mod_icons: "icons module" {
  style.fill: "#ecfdf5"
  style.stroke: "#065f46"
  style.multiple: true

  go.mod_icons: "go.mod\nmodule .../icons" {shape: page; style.fill: "#d1fae5"}
  icons_pkg: icons {
    style.fill: "#d1fae5"
    "102 Name consts · IconPathData\n(standalone-importable)"
  }
}

