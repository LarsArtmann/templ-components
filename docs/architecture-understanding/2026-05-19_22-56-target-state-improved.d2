direction: down

title: templ-components — Target Architecture (Improved)

# Foundation layer
utils: {
  shape: package
  style.fill: "#E8F5E9"
  "BaseProps (with ComponentProps interface)"
  "Class()"
  "MapEnum[T]"
  "FeedbackLevel enum"
  "MergeAttrs"
  "Test Helpers"
}

"internal/svg": {
  shape: package
  style.fill: "#FFF3E0"
  "IconRenderer"
  "SpinnerSVG"
  "(unified 24x24 stroke + optional fill)"
}

icons: {
  shape: package
  style.fill: "#E3F2FD"
  "Icon (44 names)"
  "iconPathData map"
  "IconPathJS() — validates + matches strokeIcon"
  "(Exclamation removed)"
}

# Shared JS runtime
"tc-init.js": {
  shape: rectangle
  style.fill: "#FFEBEE"
  "tc.register(id, initFn)"
  "tc.dismiss(selector)"
  "tc.onSwap(callback)"
  "Loaded once by layout.Base"
}

# Component packages
display: {
  shape: package
  style.fill: "#FCE4EC"
  "Card (subsumes SimpleCard)"
  "Accordion"
  "Avatar"
  "Badge / StatusBadge"
  "Dropdown (typed item variants)"
  "EmptyState"
  "Modal"
  "Table"
  "Tabs"
  "Tooltip"
}

feedback: {
  shape: package
  style.fill: "#F3E5F5"
  "Alert (FeedbackLevel)"
  "Toast (FeedbackLevel)"
  "Spinner"
  "ProgressBar (clamped %)"
  "StepIndicator (with BaseProps)"
  "Skeleton / SkeletonGroup"
  "LoadingOverlay (props struct)"
  "shared styleMap (merged)"
}

forms: {
  shape: package
  style.fill: "#E0F7FA"
  "Input / Checkbox"
  "Select / Textarea"
  "Label / FieldError"
  "ErrorAttrs()"
}

htmx: {
  shape: package
  style.fill: "#FFF8E1"
  "LoadingIndicator"
  "LoadingButton"
  "ConfirmDelete"
  "SwapOOB (validated swapStyle)"
  "CSRFToken"
  "GlobalErrorHandling (configurable)"
}

layout: {
  shape: package
  style.fill: "#ECEFF1"
  "Base (PageProps with validation)"
  "Minimal (MinimalProps)"
  "ThemeScript"
  "ThemeToggle (multi-instance safe)"
  "SRI management"
}

navigation: {
  shape: package
  style.fill: "#EFEBE9"
  "Nav / SimpleNav"
  "NavLink / MobileNavLink"
  "Breadcrumbs (uses icon system)"
  "Pagination (validated CurrentPage)"
  "MobileMenu"
  "Footer"
}

# Clean compile-time dependencies
icons -> utils: "imports"
"internal/svg" -> utils: "imports"
display -> utils: "imports"
display -> "internal/svg": "imports"
display -> icons: "imports"
feedback -> utils: "imports (FeedbackLevel)"
feedback -> "internal/svg": "imports"
feedback -> icons: "imports"
forms -> utils: "imports"
htmx -> utils: "imports"
layout -> utils: "imports"
layout -> icons: "imports"
navigation -> utils: "imports"
navigation -> icons: "imports"
navigation -> "internal/svg": "imports"

# JS runtime loaded by layout
layout -> "tc-init.js": "emits <script>" {
  style.stroke: "#1565C0"
  style.stroke-dash: 3
}

# Components use tc-init
display -> "tc-init.js": "accordion, dropdown, modal JS" {
  style.stroke: "#1565C0"
  style.stroke-dash: 3
}
feedback -> "tc-init.js": "toast, alert dismiss JS" {
  style.stroke: "#1565C0"
  style.stroke-dash: 3
}
navigation -> "tc-init.js": "mobile menu JS" {
  style.stroke: "#1565C0"
  style.stroke-dash: 3
}

# No more runtime JS coupling between htmx and feedback
# tc-init.js provides the bridge instead

# External dependencies (same as current)
utils -> "tailwind-merge-go": {
  style.stroke: "#9E9E9E"
  style.stroke-dash: 5
}
utils -> "a-h/templ": {
  style.stroke: "#9E9E9E"
  style.stroke-dash: 5
}
