<dialog id="confirm-modal" class="bg-white dark:bg-gray-900 dark:shadow-black/20 max-w-md overflow-hidden rounded-lg shadow-xl tc-modal tc-overlay" aria-labelledby="confirm-modal-title"><div class="border-b border-gray-200 dark:border-gray-700 flex items-center justify-between px-4 py-3 sm:px-6"><h2 id="confirm-modal-title" class="dark:text-white font-semibold text-base text-gray-900">Confirm Action</h2><button type="button" class="dark:focus:ring-blue-400 dark:hover:text-gray-300 dark:text-gray-500 focus:outline-hidden focus:ring-2 focus:ring-blue-500 hover:text-gray-500 rounded-md text-gray-400" data-tc-close="modal" aria-label="Close"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg></button></div><div class="px-4 py-4 sm:px-6"></div></dialog><script nonce="nonce123">
if(!window.tcOverlayModalAttached){window.tcOverlayModalAttached=true;window.tcOpenModal=function(id){var d=document.getElementById(id);if(d&&typeof d.showModal==='function')d.showModal();};window.tcCloseModal=function(id){var d=document.getElementById(id);if(d)d.close();};}(function(id){var d=document.getElementById(id);if(!d)return;if(d.hasAttribute('data-tc-open')&&!d.open)d.showModal();d.addEventListener('click',function(e){if(e.target.closest('[data-tc-close]')||e.target===d)d.close();});})("confirm-modal");
</script>