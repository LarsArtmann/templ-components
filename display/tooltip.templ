package display

import "github.com/larsartmann/templ-components/utils"

// TooltipPosition defines where the tooltip appears relative to the trigger
type TooltipPosition string

const (
	TooltipPositionTop    TooltipPosition = "top"
	TooltipPositionBottom TooltipPosition = "bottom"
	TooltipPositionLeft   TooltipPosition = "left"
	TooltipPositionRight  TooltipPosition = "right"
)

// TooltipProps configures a tooltip component
type TooltipProps struct {
	utils.BaseProps
	Text     string
	Position TooltipPosition
}

// DefaultTooltipProps returns sensible defaults
func DefaultTooltipProps() TooltipProps {
	return TooltipProps{
		Position: TooltipPositionTop,
	}
}

func tooltipPositionClass(pos TooltipPosition) string {
	switch pos {
	case TooltipPositionBottom:
		return "top-full left-1/2 -translate-x-1/2 mt-2"
	case TooltipPositionLeft:
		return "right-full top-1/2 -translate-y-1/2 mr-2"
	case TooltipPositionRight:
		return "left-full top-1/2 -translate-y-1/2 ml-2"
	default:
		return "bottom-full left-1/2 -translate-x-1/2 mb-2"
	}
}

func tooltipArrowClass(pos TooltipPosition) string {
	switch pos {
	case TooltipPositionBottom:
		return "bottom-full left-1/2 -translate-x-1/2 border-b-gray-900 dark:border-b-gray-700"
	case TooltipPositionLeft:
		return "left-full top-1/2 -translate-y-1/2 border-l-gray-900 dark:border-l-gray-700"
	case TooltipPositionRight:
		return "right-full top-1/2 -translate-y-1/2 border-r-gray-900 dark:border-r-gray-700"
	default:
		return "top-full left-1/2 -translate-x-1/2 border-t-gray-900 dark:border-t-gray-700"
	}
}

// Tooltip wraps content in a hover-activated tooltip
//
//	@display.Tooltip(display.TooltipProps{Text: "More info"}) {
//	   <button>Hover me</button>
//	 }
templ Tooltip(props TooltipProps) {
	<div
		if props.ID != "" {
			id={ props.ID }
		}
		class={ utils.Class("group relative inline-flex", props.Class) }
		{ props.Attrs... }
	>
		{ children... }
		<div
			class={ "absolute z-20 hidden group-hover:block group-focus-within:block whitespace-nowrap rounded-md bg-gray-900 dark:bg-gray-700 px-2 py-1 text-xs font-medium text-white shadow-sm",
				tooltipPositionClass(props.Position) }
			role="tooltip"
		>
			{ props.Text }
			<div class={ "absolute h-0 w-0 border-4 border-transparent", tooltipArrowClass(props.Position) }></div>
		</div>
	</div>
}
