<div class="bg-yellow-50 border border-yellow-200 dark:bg-yellow-900/20 dark:border-yellow-800 p-4 rounded-md" role="alert"><div class="flex"><div class="flex-shrink-0"><svg class="dark:text-yellow-400 h-5 text-yellow-600 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.664-.833-2.464 0L4.35 16.5c-.77.833.192 2.5 1.732 2.5z"></path></svg></div><div class="flex-1 ms-3"><h3 class="dark:text-yellow-200 font-medium text-sm text-yellow-800">Warning</h3><div class="dark:text-yellow-200 text-sm text-yellow-800"><p></p></div></div><div class="ms-auto ps-3"><div class="-mx-1.5 -my-1.5"><button type="button" class="bg-yellow-50 dark:bg-yellow-900/20 dark:focus:ring-offset-gray-900 dark:text-yellow-200 focus:outline-hidden focus:ring-2 focus:ring-offset-2 hover:opacity-80 inline-flex p-1.5 rounded-md text-yellow-800" data-dismiss="alert" aria-label="Dismiss"><svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg></button></div></div></div><script nonce="">if(!window.tcDismissAttached){window.tcDismissAttached=true;document.addEventListener('click',function(e){var btn=e.target.closest('[data-dismiss]');if(btn){var el=btn.closest('[role="alert"],[role="status"]');if(el)el.remove();}});}</script></div>